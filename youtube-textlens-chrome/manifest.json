{
  "manifest_version": 3,
  "name": "TextLens YouTube",
  "description": "Detects YouTube videos and renders synced TextLens subtitles over the player.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TextLens YouTube"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
